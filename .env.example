# Required: Your Yandex OAuth token with metrika:read scope
# Get one at: https://oauth.yandex.com/
YANDEX_METRICA_TOKEN=your_oauth_token_here

# Optional: Request timeout in milliseconds (default: 30000)
# YANDEX_METRICA_TIMEOUT_MS=30000

# Optional: Log level (default: info)
# LOG_LEVEL=info

# Optional: Custom User-Agent header
# YANDEX_METRICA_USER_AGENT=mcp-yandex-metrica/0.1.0

# Optional: Override API base URL (for testing only, do not change in production)
# YANDEX_METRICA_BASE_URL=https://api-metrika.yandex.net

# For live tests only: counter ID to use in live test runs
# YANDEX_METRICA_COUNTER_ID=12345678
